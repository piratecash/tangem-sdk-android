<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:paddingTop="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include android:id="@+id/layoutCard" layout="@layout/card" />

        <include android:id="@+id/layoutAttestation" layout="@layout/attestation" />

        <include android:id="@+id/layoutWallet" layout="@layout/wallet" />

        <include android:id="@+id/layoutSign" layout="@layout/sign" />

        <include android:id="@+id/layoutHdWallet" layout="@layout/hd_wallet" />

        <include android:id="@+id/layoutBackup" layout="@layout/backup" />

        <include android:id="@+id/layoutIssuerData" layout="@layout/issuer_data" />

        <include android:id="@+id/layoutIssuerExData" layout="@layout/issuer_ex_data" />

        <include android:id="@+id/layoutUserData" layout="@layout/user_data" />

        <include android:id="@+id/layoutSetPin" layout="@layout/set_pin" />

        <include android:id="@+id/layoutFileData" layout="@layout/file_data" />

        <include android:id="@+id/layoutJsonRpc" layout="@layout/json_rpc" />

        <include android:id="@+id/layoutUtils" layout="@layout/utils" />

        <include android:id="@+id/layoutTheme" layout="@layout/theme" />

    </LinearLayout>

</ScrollView>