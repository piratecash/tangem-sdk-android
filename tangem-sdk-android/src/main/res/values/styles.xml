<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CardSdkTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sdk_primary</item>
        <item name="colorOnPrimary">@color/sdk_on_primary</item>
        <item name="colorSecondary">@color/sdk_secondary</item>
        <item name="colorOnSecondary">@color/sdk_on_secondary</item>
        <item name="android:colorBackground">@color/sdk_background</item>
        <item name="colorOnBackground">@color/sdk_on_background</item>
        <item name="colorSurface">@color/sdk_surface</item>
        <item name="colorOnSurface">@color/sdk_on_surface</item>
        <item name="colorError">@color/sdk_error</item>
        <item name="colorOnError">@color/sdk_on_error</item>
        <item name="bottomSheetDialogTheme">@style/SdkBottomSheetDialogStyle</item>
        <item name="materialButtonStyle">@style/CustomMaterialButtonStyle</item>
        <item name="buttonStyle">@style/CustomButtonStyle</item>
    </style>

    <style name="SdkBottomSheetDialogStyle" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
<!--        <item name="android:backgroundDimEnabled">true</item>-->
<!--        <item name="android:backgroundDimAmount">0.6</item>-->
        <item name="android:backgroundTint">@color/sdk_background</item>
        <item name="materialButtonStyle">@style/CustomMaterialButtonStyle</item>
        <item name="buttonStyle">@style/CustomButtonStyle</item>
    </style>

    <style name="CustomMaterialButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/sdk_primary</item>
        <item name="android:textColor">@color/sdk_on_background</item>
        <item name="cornerRadius">25dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="CustomButtonStyle" parent="Widget.AppCompat.Button">
        <item name="android:background">@color/sdk_primary</item>
        <item name="android:textColor">@color/sdk_on_background</item>
        <item name="cornerRadius">25dp</item>
    </style>

    <style name="CustomOutlineButtonStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/sdk_on_primary</item>
        <item name="strokeColor">@color/sdk_primary</item>
        <item name="android:textColor">@color/sdk_on_background</item>
        <item name="cornerRadius">25dp</item>
    </style>
</resources>